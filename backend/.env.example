# Copy this file to .env and fill in your values

# Database (uses existing PKA postgres at 5432)
DATABASE_URL=postgresql+asyncpg://postgres:%3FBooker78%21@localhost:5432/postgres

# Redis (general Redis)
REDIS_URL=redis://localhost:6379

# Ollama (local)
OLLAMA_URL=http://localhost:11434

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-key-here

# OpenAI (optional)
OPENAI_API_KEY=your-openai-key-here

# NVIDIA NIM (optional — key in ~/.nvidia.env)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Search providers for agent web_search tool
# Priority: Tavily > Brave > DuckDuckGo (free, no key required as fallback)
TAVILY_API_KEY=                   # https://tavily.com — best quality
BRAVE_SEARCH_API_KEY=             # https://api.search.brave.com

# Models
DEFAULT_MODEL=gemma3:latest
SYNTHESIS_MODEL=claude-sonnet-4-6

# Security — change this in production
SECRET_KEY=council-dev-secret-change-in-production

# App
ENVIRONMENT=development
